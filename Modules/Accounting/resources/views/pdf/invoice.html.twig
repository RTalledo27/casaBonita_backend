<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <style type="text/css">
        /* ===== RESET Y BASE ===== */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            font-size: 11px;
            color: #1a1a1a;
            background: #fff;
        }
        table { border-collapse: collapse; width: 100%; }

        .page { width: 100%; max-width: 800px; margin: 0 auto; padding: 25px 30px; }

        /* ===== CABECERA ===== */
        .hdr { margin-bottom: 20px; }
        .hdr td { vertical-align: top; }
        .hdr-left { width: 62%; padding-right: 20px; }
        
        .logo { max-height: 70px; max-width: 180px; margin-bottom: 10px; }
        .emp-name { font-size: 14px; font-weight: 700; margin-bottom: 4px; letter-spacing: 0.5px; text-transform: uppercase; }
        .emp-addr { font-size: 10px; color: #4a4a4a; line-height: 1.5; }

        .hdr-right {
            width: 38%;
            border: 2px solid #1a1a1a;
            text-align: center;
            padding: 15px 10px;
            border-radius: 2px;
        }
        .ruc-txt { font-size: 15px; font-weight: 700; color: #cc0000; letter-spacing: 0.5px; }
        .tipo-doc { font-size: 13px; font-weight: 700; margin: 8px 0; letter-spacing: 0.5px; }
        .num-doc { font-size: 15px; font-weight: 700; letter-spacing: 1px; }

        /* ===== SECCIÓN CLIENTE ===== */
        .cli { 
            border: 1px solid #d4d4d4; 
            margin-bottom: 20px; 
            border-radius: 2px;
        }
        .cli td { padding: 6px 10px; font-size: 11px; }
        .cli tr { border-bottom: 1px solid #eeeeee; }
        .cli tr:last-child { border-bottom: none; }
        
        .cli .lb { font-weight: 700; width: 12%; color: #333; }
        .cli .vl { width: 48%; color: #1a1a1a; }
        .cli .lb2 { font-weight: 700; width: 15%; text-align: right; padding-right: 15px; color: #333; }
        .cli .vl2 { width: 25%; color: #1a1a1a; }

        /* ===== DETALLE DE PRODUCTOS ===== */
        .det { margin-bottom: 20px; border: 1px solid #1a1a1a; }
        .det th {
            background: #1a1a1a;
            color: #ffffff;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            padding: 8px 5px;
            text-align: center;
            letter-spacing: 0.5px;
            border-right: 1px solid #444;
        }
        .det th:last-child { border-right: none; }
        
        .det td {
            padding: 8px 5px;
            font-size: 11px;
            border-bottom: 1px solid #e0e0e0;
            border-right: 1px solid #e0e0e0;
            color: #1a1a1a;
        }
        .det td:last-child { border-right: none; }
        .det tbody tr:last-child td { border-bottom: none; }
        
        /* Cebra sutil para las filas */
        .det tbody tr:nth-child(even) { background-color: #fafafa; }

        /* ===== PIE: LEYENDA + TOTALES ===== */
        .pie td { vertical-align: top; }
        
        /* Izquierda: Leyendas y QR */
        .pie-left { width: 60%; padding-right: 25px; }
        .son {
            border: 1px solid #d4d4d4;
            background-color: #fafafa;
            padding: 8px 12px;
            font-size: 10px;
            font-weight: 700;
            margin-bottom: 12px;
            color: #1a1a1a;
            border-radius: 2px;
        }
        .obs { font-size: 9px; color: #555; line-height: 1.6; margin-bottom: 8px; }
        .hash { font-size: 9px; color: #777; word-break: break-all; margin-top: 5px; }
        .qr { margin-top: 10px; }
        .qr img { width: 110px; height: 110px; border: 1px solid #eeeeee; padding: 4px; }

        .extras { margin-top: 8px; }
        .extras td { padding: 2px 0; font-size: 9px; color: #555; }
        .extras strong { color: #333; }

        /* Derecha: Tabla de Totales */
        .tot { border: 1px solid #1a1a1a; border-radius: 2px; }
        .tot td { padding: 7px 12px; font-size: 11px; }
        .tot tr { border-bottom: 1px solid #e0e0e0; }
        .tot tr:last-child { border-bottom: none; }
        
        .tot .tl { text-align: right; font-weight: 600; color: #4a4a4a; width: 60%; border-right: 1px solid #e0e0e0;}
        .tot .ta { text-align: right; width: 40%; font-weight: 500;}
        
        .tot-total { background: #1a1a1a; color: #ffffff; }
        .tot-total td { 
            padding: 10px 12px; 
            font-size: 13px; 
            font-weight: 700; 
            border: none;
            color: #ffffff; 
        }
        .tot-total .tl { border-right: none; color: #ffffff; }

        /* ===== FOOTER LEGAL ===== */
        .foot {
            margin-top: 30px;
            border-top: 1px solid #d4d4d4;
            padding-top: 12px;
            text-align: center;
            font-size: 9px;
            color: #666;
            line-height: 1.6;
        }
    </style>
</head>
<body>
    {% set cp = doc.company %}
    {% set isInvoice = doc.tipoDoc in ['01', '03'] %}
    {% set isNota = doc.tipoDoc in ['07', '08'] %}
    {% set name = doc.tipoDoc|catalog('01') %}

    <div class="page">
        <table class="hdr">
            <tr>
                <td class="hdr-left">
                    {% if params.system.logo %}
                        <img src="{{ params.system.logo|image_b64 }}" class="logo"><br>
                    {% endif %}
                    <div class="emp-name">{{ cp.razonSocial }}</div>
                    <div class="emp-addr">
                        {{ cp.address.direccion }}<br>
                        {{ cp.address.distrito }} - {{ cp.address.provincia }} - {{ cp.address.departamento }}
                    </div>
                    {% if params.user.header %}
                        <div class="emp-addr" style="margin-top:6px;">{{ params.user.header|raw }}</div>
                    {% endif %}
                </td>
                <td class="hdr-right">
                    <div class="ruc-txt">R.U.C. {{ cp.ruc }}</div>
                    <div class="tipo-doc">{{ name|upper }}<br>ELECTRÓNICA</div>
                    <div class="num-doc">{{ doc.serie }} - {{ doc.correlativo }}</div>
                </td>
            </tr>
        </table>

        <table class="cli">
            {% set cl = doc.client %}
            <tr>
                <td class="lb">Señor(es):</td>
                <td class="vl">{{ cl.rznSocial }}</td>
                <td class="lb2">F. Emisión:</td>
                <td class="vl2">{{ doc.fechaEmision|date('d/m/Y') }}</td>
            </tr>
            <tr>
                <td class="lb">{{ cl.tipoDoc|catalog('06') }}:</td>
                <td class="vl">{{ cl.numDoc }}</td>
                <td class="lb2">Moneda:</td>
                <td class="vl2">{{ doc.tipoMoneda|catalog('021') }}</td>
            </tr>
            <tr>
                <td class="lb">Dirección:</td>
                <td colspan="3" class="vl">{% if cl.address %}{{ cl.address.direccion }}{% endif %}</td>
            </tr>
            {% if doc.fecVencimiento %}
            <tr>
                <td class="lb">Vencimiento:</td>
                <td colspan="3" class="vl">{{ doc.fecVencimiento|date('d/m/Y') }}</td>
            </tr>
            {% endif %}
            {% if isNota %}
            <tr>
                <td class="lb">Doc. Afectado:</td>
                <td colspan="3" class="vl">{{ doc.tipDocAfectado|catalog('01') }} {{ doc.numDocfectado }}</td>
            </tr>
            <tr>
                <td class="lb">Motivo:</td>
                <td colspan="3" class="vl">{{ doc.desMotivo }}</td>
            </tr>
            {% endif %}
        </table>

        <table class="det">
            <thead>
                <tr>
                    <th style="width:8%;">Cant.</th>
                    <th style="width:10%;">Und.</th>
                    <th style="width:12%;">Código</th>
                    <th>Descripción</th>
                    <th style="width:15%;">V. Unitario</th>
                    <th style="width:15%;">Importe</th>
                </tr>
            </thead>
            <tbody>
                {% set moneda = doc.tipoMoneda|catalog('02') %}
                {% for det in doc.details %}
                <tr>
                    <td align="center">{{ det.cantidad|n_format }}</td>
                    <td align="center">{{ det.unidad }}</td>
                    <td align="center">{{ det.codProducto }}</td>
                    <td>{{ det.descripcion }}</td>
                    <td align="right">{{ moneda }} {{ det.mtoValorUnitario|n_format }}</td>
                    <td align="right">{{ moneda }} {{ det.mtoValorVenta|n_format }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <table class="pie">
            <tr>
                <td class="pie-left">
                    <div class="son">SON: {{ legend(doc.legends, '1000') }}</div>

                    {% if doc.legends %}
                        <div class="obs">
                        {% for leg in doc.legends %}
                            {% if leg.code != '1000' %}&bull; {{ leg.value }}<br>{% endif %}
                        {% endfor %}
                        </div>
                    {% endif %}

                    {% if params.user.extras %}
                        <table class="extras" cellpadding="0">
                        {% for item in params.user.extras %}
                            <tr><td><strong>{{ item.name|upper }}:</strong> {{ item.value }}</td></tr>
                        {% endfor %}
                        </table>
                    {% endif %}

                    {% if params.system.hash %}
                        <div class="hash"><strong>Resumen Hash:</strong> {{ params.system.hash }}</div>
                    {% endif %}

                    <div class="qr">
                        <img src="{{ qrCode(doc)|image_b64('svg+xml') }}" alt="Código QR">
                    </div>
                </td>
                <td style="width:40%;">
                    <table class="tot">
                        {% if doc.mtoOperGravadas %}
                        <tr>
                            <td class="tl">Op. Gravadas</td>
                            <td class="ta">{{ moneda }} {{ doc.mtoOperGravadas|n_format }}</td>
                        </tr>
                        {% endif %}
                        {% if doc.mtoOperExoneradas %}
                        <tr>
                            <td class="tl">Op. Exoneradas</td>
                            <td class="ta">{{ moneda }} {{ doc.mtoOperExoneradas|n_format }}</td>
                        </tr>
                        {% endif %}
                        {% if doc.mtoOperInafectas %}
                        <tr>
                            <td class="tl">Op. Inafectas</td>
                            <td class="ta">{{ moneda }} {{ doc.mtoOperInafectas|n_format }}</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td class="tl">I.G.V. (18%)</td>
                            <td class="ta">{{ moneda }} {{ doc.mtoIGV|n_format }}</td>
                        </tr>
                        <tr class="tot-total">
                            <td class="tl">IMPORTE TOTAL</td>
                            <td class="ta">{{ moneda }} {{ doc.mtoImpVenta|n_format }}</td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="foot">
            Representación impresa de la {{ name|upper }} ELECTRÓNICA<br>
            Consulte su comprobante en:<br>
            <strong>https://e-consulta.sunat.gob.pe/ol-ti-itconsvalicpe/ConsValiCpe.htm</strong>
        </div>
    </div>
</body>
</html>